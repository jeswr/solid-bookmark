{
  "name": "@jeswr/solid-bookmark",
  "version": "0.1.0",
  "description": "The RDF vocabulary + typed model for bookmarks / read-it-later (the data model for a Linkding→Solid fork) — book:Bookmark over reused dereferenceable terms (schema.org / Dublin Core / SKOS) rooted in the suite core, plus the ontology TTL and SHACL shape that pin the contract.",
  "type": "module",
  "license": "MIT",
  "author": "Jesse Wright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/solid-bookmark.git"
  },
  "homepage": "https://github.com/jeswr/solid-bookmark#readme",
  "bugs": {
    "url": "https://github.com/jeswr/solid-bookmark/issues"
  },
  "keywords": [
    "solid",
    "rdf",
    "bookmark",
    "read-it-later",
    "linkding",
    "schema.org",
    "shacl",
    "vocabulary"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vocab": {
      "types": "./dist/vocab.d.ts",
      "import": "./dist/vocab.js"
    },
    "./shape": {
      "types": "./dist/shape.d.ts",
      "import": "./dist/shape.js"
    },
    "./bookmark.ttl": "./bookmark.ttl",
    "./bookmark.shacl.ttl": "./bookmark.shacl.ttl"
  },
  "files": [
    "dist",
    "bookmark.ttl",
    "bookmark.shacl.ttl",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@jeswr/fetch-rdf": "^0.1.0",
    "@rdfjs/wrapper": "^0.34.0",
    "n3": "^2.0.3"
  },
  "peerDependencies": {
    "@rdfjs/types": "^2.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
